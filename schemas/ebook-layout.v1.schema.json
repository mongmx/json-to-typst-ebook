{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flywheel.local/schemas/ebook-layout.v1.schema.json",
  "title": "Ebook Layout Content Package",
  "description": "Contract between an upstream content agent and the Typst ebook layout engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "book", "chapters"],
  "properties": {
    "schema_version": {
      "const": "ebook-layout.v1"
    },
    "book": {
      "$ref": "#/$defs/book"
    },
    "layout": {
      "$ref": "#/$defs/layoutOptions"
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapter"
      }
    }
  },
  "$defs": {
    "book": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "volume": {
          "type": "string"
        },
        "footer": {
          "type": "string"
        }
      }
    },
    "layoutOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "default": "habit-workbook"
        },
        "theme": {
          "type": "string",
          "default": "navy-yellow"
        },
        "page_size": {
          "enum": ["a4"]
        }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "slug", "title", "sections"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "sections": {
          "$ref": "#/$defs/chapterSections"
        }
      }
    },
    "chapterSections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hook", "concept", "examples", "drills", "reflection"],
      "properties": {
        "hook": {
          "$ref": "#/$defs/blockSection"
        },
        "concept": {
          "$ref": "#/$defs/blockSection"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/example"
          }
        },
        "drills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/drill"
          }
        },
        "reflection": {
          "$ref": "#/$defs/reflection"
        }
      }
    },
    "blockSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocks"],
      "properties": {
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "blocks"],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      }
    },
    "drill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "title", "blocks"],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      }
    },
    "reflection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "closing": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        }
      },
      "anyOf": [
        {
          "required": ["prompts"]
        },
        {
          "required": ["blocks"]
        }
      ]
    },
    "contentBlock": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {
              "const": "paragraph"
            },
            "text": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "items"],
          "properties": {
            "type": {
              "const": "unordered_list"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "items"],
          "properties": {
            "type": {
              "const": "ordered_list"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "start": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      ]
    }
  }
}
